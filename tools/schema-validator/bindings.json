{
  "schema_version": 1,
  "bindings": [
    { "schema": "schemas/lizard-agent-layer.schema.json", "include": ["profiles/*.json", "examples/*.agent-layer.json"] },
    { "schema": "schemas/pack.schema.json", "include": ["packs/*.json"] },
    { "schema": "schemas/adapter.schema.json", "include": ["adapters/*/adapter.json"] },
    { "schema": "schemas/model-profile.schema.json", "include": ["model-profiles/*.json"] },
    { "schema": "schemas/loop.schema.json", "include": ["loops/*.json"], "exclude": ["loops/registry.json"] },
    { "schema": "schemas/loop-registry.schema.json", "include": ["loops/registry.json"] },
    { "schema": "schemas/quality-registry.schema.json", "include": ["registry/quality-rubric.json"] },
    { "schema": "schemas/maturity-levels.schema.json", "include": ["registry/maturity-levels.json"] },
    { "schema": "schemas/risk-signals.schema.json", "include": ["registry/risk-signals.json"] },
    { "schema": "schemas/manifest-migrations.schema.json", "include": ["registry/manifest-migrations.json"] },
    { "schema": "schemas/drift-baseline.schema.json", "include": ["registry/drift-baseline.json"] },
    { "schema": "schemas/merge-suggestions-report.schema.json", "include": ["tests/schema/fixtures/merge-suggestions-report.valid.json"] },
    { "schema": "schemas/behavioral-readiness.schema.json", "include": ["registry/behavioral-readiness.json"] },
    { "schema": "schemas/skill-evidence.schema.json", "include": ["skills/*/evidence.json"] },
    { "schema": "schemas/contracts.schema.json", "include": ["registry/contracts.json"] },
    { "schema": "schemas/contract-change.schema.json", "include": ["changes/*.json"] },
    { "schema": "schemas/loop-runtime-budget.schema.json", "include": ["templates/loops/loop-runtime-budget.json"] },
    { "schema": "schemas/loop-runtime-state.schema.json", "include": ["tests/schema/fixtures/loop-runtime-state.valid.json"] },
    { "schema": "schemas/loop-runtime-lease.schema.json", "include": ["tests/schema/fixtures/loop-runtime-lease.valid.json"] },
    { "schema": "schemas/loop-runtime-event.schema.json", "include": ["tests/schema/fixtures/loop-runtime-event.valid.json"] },
    { "schema": "schemas/loop-runtime-report.schema.json", "include": ["tests/schema/fixtures/loop-runtime-report.valid.json"] }
  ]
