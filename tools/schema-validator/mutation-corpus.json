{
  "schema_version": 1,
  "cases": [
    {
      "name": "profile-required-field",
      "schema": "schemas/lizard-agent-layer.schema.json",
      "base": "profiles/minimal.json",
      "mutations": [{ "op": "remove", "path": "/riskLevel" }],
      "expected_keyword": "required"
    },
    {
      "name": "profile-nested-type",
      "schema": "schemas/lizard-agent-layer.schema.json",
      "base": "profiles/minimal.json",
      "mutations": [{ "op": "replace", "path": "/modelProfiles", "value": [] }],
      "expected_keyword": "type"
    },
    {
      "name": "profile-enum",
      "schema": "schemas/lizard-agent-layer.schema.json",
      "base": "profiles/minimal.json",
      "mutations": [{ "op": "replace", "path": "/riskLevel", "value": "extreme" }],
      "expected_keyword": "enum"
    },
    {
      "name": "profile-unknown-field",
      "schema": "schemas/lizard-agent-layer.schema.json",
      "base": "profiles/minimal.json",
      "mutations": [{ "op": "add", "path": "/unexpected", "value": true }],
      "expected_keyword": "additionalProperties"
    },
    {
      "name": "adapter-unsafe-path",
      "schema": "schemas/adapter.schema.json",
      "base": "adapters/codex/adapter.json",
      "mutations": [{ "op": "replace", "path": "/instruction/dst", "value": "../../escape.md" }],
      "expected_keyword": "pattern"
    },
    {
      "name": "loop-cadence-type",
      "schema": "schemas/loop.schema.json",
      "base": "loops/daily-triage.json",
      "mutations": [{ "op": "replace", "path": "/cadence", "value": [] }],
      "expected_keyword": "type"
    },
    {
      "name": "loop-nested-required",
      "schema": "schemas/loop.schema.json",
      "base": "loops/daily-triage.json",
      "mutations": [{ "op": "remove", "path": "/cadence/notes" }],
      "expected_keyword": "required"
    },
    {
      "name": "loop-nested-unknown",
      "schema": "schemas/loop.schema.json",
      "base": "loops/daily-triage.json",
      "mutations": [{ "op": "add", "path": "/cadence/unexpected", "value": true }],
      "expected_keyword": "additionalProperties"
    },
    {
      "name": "risk-severity-enum",
      "schema": "schemas/risk-signals.schema.json",
      "base": "registry/risk-signals.json",
      "mutations": [{ "op": "replace", "path": "/signals/0/severity", "value": "unknown" }],
      "expected_keyword": "enum"
    },
    {
      "name": "merge-report-sensitivity-contract",
      "schema": "schemas/merge-suggestions-report.schema.json",
      "base": "tests/schema/fixtures/merge-suggestions-report.valid.json",
      "mutations": [{ "op": "replace", "path": "/include_existing_context", "value": true }],
      "expected_keyword": "const"
    },
    {
      "name": "merge-report-unsafe-instruction-path",
      "schema": "schemas/merge-suggestions-report.schema.json",
      "base": "tests/schema/fixtures/merge-suggestions-report.valid.json",
      "mutations": [{ "op": "replace", "path": "/results/0/instruction_path", "value": "../../private.md" }],
      "expected_keyword": "pattern"
    },
    {
      "name": "skill-evidence-requires-both-fixture-kinds",
      "schema": "schemas/skill-evidence.schema.json",
      "base": "skills/loop-verifier/evidence.json",
      "mutations": [{ "op": "remove", "path": "/fixtures/1" }],
      "expected_keyword": "minItems"
    },
    {
      "name": "skill-evidence-rejects-unsafe-test-path",
      "schema": "schemas/skill-evidence.schema.json",
      "base": "skills/loop-verifier/evidence.json",
      "mutations": [{ "op": "replace", "path": "/fixtures/0/test_path", "value": "../../outside.tests.ps1" }],
      "expected_keyword": "pattern"
