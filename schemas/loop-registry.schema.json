{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/loop-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "patterns"],
  "properties": {
    "schema_version": { "const": 1 },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "file", "readinessLevel", "riskLevel", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
          "file": { "type": "string", "pattern": "^loops/[a-z0-9][a-z0-9-]{0,62}\\.json$" },
          "readinessLevel": { "enum": ["L0", "L1", "L2", "L3"] },
          "riskLevel": { "enum": ["low", "medium", "high"] },
          "description": { "type": "string", "minLength": 10 }
        }
      }
    }
  }
}
