{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/loop-state.schema.json",
  "title": "lizard-agent-layer loop state",
  "type": "object",
  "required": ["schema_version", "loop", "readiness_level", "last_run", "items"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "loop": { "type": "string" },
    "readiness_level": { "enum": ["L0", "L1", "L2", "L3"] },
    "last_run": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "summary", "attempts"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["watch", "waiting-human", "in-progress", "resolved", "blocked"] },
          "summary": { "type": "string" },
          "attempts": { "type": "integer", "minimum": 0 },
          "last_action": { "type": "string" },
          "next_action": { "type": "string" },
          "owner": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
