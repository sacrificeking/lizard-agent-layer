{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.dev/schemas/loop-runtime-budget.schema.json",
  "title": "lizard-agent-layer executable loop budget",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "daily_token_cap", "max_runs_per_day", "max_attempts_per_item", "lease_minutes", "on_exceed"],
  "properties": {
    "schema_version": { "const": 1 },
    "daily_token_cap": { "type": "integer", "minimum": 1 },
    "max_runs_per_day": { "type": "integer", "minimum": 1 },
    "max_attempts_per_item": { "type": "integer", "minimum": 1 },
    "lease_minutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
    "on_exceed": { "enum": ["pause"] }
  }
}
