{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/loop-budget.schema.json",
  "title": "lizard-agent-layer loop budget",
  "type": "object",
  "required": ["schema_version", "daily_token_cap", "max_runs_per_day", "max_subagents_per_run", "on_exceed"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "daily_token_cap": { "type": "integer", "minimum": 1 },
    "max_runs_per_day": { "type": "integer", "minimum": 1 },
    "max_subagents_per_run": { "type": "integer", "minimum": 0 },
    "max_attempts_per_item": { "type": "integer", "minimum": 1 },
    "on_exceed": { "enum": ["pause", "report-only", "human-gate"] },
    "cheap_model_roles": { "type": "array", "items": { "type": "string" } },
    "strong_model_roles": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
