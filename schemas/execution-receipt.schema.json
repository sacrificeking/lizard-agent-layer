{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/execution-receipt.schema.json",
  "title": "lizard-agent-layer attested execution receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "receipt_id", "route_decision_id", "created_at", "started_at", "completed_at", "executor_id", "configuration_fingerprint", "harness", "actual_model", "actual_provider", "reasoning_setting", "attestation", "attestation_source", "outcome", "raw_prompt_stored"],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "execution-receipt" },
    "receipt_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "route_decision_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "executor_id": { "type": "string", "minLength": 1 },
    "configuration_fingerprint": { "type": "string", "minLength": 1, "maxLength": 200 },
    "harness": { "type": "string", "minLength": 1 },
    "actual_model": { "type": "string", "minLength": 1 },
    "actual_provider": { "type": "string", "minLength": 1 },
    "reasoning_setting": { "type": ["string", "null"] },
    "attestation": { "enum": ["observed", "attested"] },
    "attestation_source": { "type": "string", "minLength": 1 },
    "outcome": { "enum": ["succeeded", "failed", "cancelled"] },
    "evidence_ref": { "type": ["string", "null"], "maxLength": 500 },
    "raw_prompt_stored": { "const": false }
  }
}
