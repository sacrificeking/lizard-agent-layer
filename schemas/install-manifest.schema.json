{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/install-manifest.schema.json",
  "title": "lizard-agent-layer install manifest v3",
  "type": "object",
  "required": [
    "schema_version",
    "layer",
    "layer_version",
    "minimum_reader_schema_version",
    "writer_schema_version",
    "profile",
    "harnesses",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "layer": { "const": "lizard-agent-layer" },
    "layer_version": { "type": "string" },
    "minimum_reader_schema_version": { "type": "integer", "minimum": 2, "maximum": 3 },
    "writer_schema_version": { "const": 3 },
    "migrated_from_schema_version": { "type": "integer", "minimum": 1, "maximum": 2 },
    "profile": { "type": "string" },
    "requested_packs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "pack_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source", "path"],
        "properties": {
          "name": { "type": "string" },
          "source": { "enum": ["builtin", "target-overlay"] },
          "path": { "type": "string" }
        }
      }
    },
    "packs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "installed_at": { "type": "string", "format": "date-time" },
    "target_root": { "type": "string", "minLength": 1 },
    "memory_mode": { "enum": ["curated", "private-episodic", "off"] },
    "risk_level": { "enum": ["low", "medium", "high"] },
    "harnesses": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "model_profiles": { "type": "object", "additionalProperties": { "type": "string" }, "deprecated": true },
    "model_mode": { "enum": ["inherit-current", "inventory-routing"] },
    "model_inventory": { "type": ["string", "null"], "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$" },
    "model_runtime": { "type": ["string", "null"], "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$" },
    "routing_policy": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "routing_models": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "deprecated": true },
    "skills": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "adapters": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "adapter_aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["adapter", "satisfied_by", "destination"],
        "properties": {
          "adapter": { "type": "string" },
          "satisfied_by": { "type": "string" },
          "destination": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "ownership", "state", "source_version", "adapter_aliases"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(^|/)\\.\\.(/|$)).+$" },
          "kind": { "enum": ["file", "directory"] },
          "ownership": { "enum": ["layer-owned", "user-owned", "adopted"] },
          "state": { "enum": ["layer-owned", "user-owned", "adopted", "locally-modified", "stale-unmodified", "missing", "conflict", "integrity-unknown"] },
          "source_path": { "type": ["string", "null"] },
          "source_version": { "type": ["string", "null"] },
          "source_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "installed_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "current_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "adapter_id": { "type": ["string", "null"] },
          "adapter_aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "mirror_group": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "managed_paths": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "owned_paths": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "merge_needed": { "type": "array", "items": { "type": "string" } },
    "merge_suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["harness", "instruction_path", "sidecar_path", "action", "suggested_block"],
        "properties": {
          "harness": { "type": "string" },
          "instruction_path": { "type": "string" },
          "sidecar_path": { "type": "string" },
          "action": { "type": "string" },
          "suggested_block": { "type": "string" }
        }
      }
    },
    "conflicts": { "type": "array", "items": { "type": "string" } },
    "transaction_operation_id": { "type": "string", "pattern": "^[a-f0-9]{32}$" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "model_mode": { "const": "inventory-routing" } }, "required": ["model_mode"] },
      "then": {
        "required": ["model_inventory", "model_runtime"],
        "properties": {
          "model_inventory": { "type": "string" },
          "model_runtime": { "type": "string" }
        }
      }
    }
  ]
}
