{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.dev/schemas/loop-runtime-lease.schema.json",
  "title": "lizard-agent-layer loop lease",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pattern", "status", "run_id", "owner", "acquired_at", "expires_at", "released_at"],
  "properties": {
    "schema_version": { "const": 1 }, "pattern": { "type": "string" }, "status": { "enum": ["available", "active", "released", "recovered"] }, "run_id": { "type": ["string", "null"] }, "owner": { "type": ["string", "null"] }, "acquired_at": { "type": ["string", "null"], "format": "date-time" }, "expires_at": { "type": ["string", "null"], "format": "date-time" }, "released_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
