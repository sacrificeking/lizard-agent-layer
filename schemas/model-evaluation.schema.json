{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/model-evaluation.schema.json",
  "title": "Attested model role evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evaluation_id", "model_id", "provider", "suite", "evaluated_at", "expires_at", "executor_id", "configuration_fingerprint", "attestation", "cases", "raw_prompts_stored"],
  "properties": {
    "schema_version": { "const": 1 },
    "evaluation_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "model_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "provider": { "type": "string", "minLength": 1, "maxLength": 100 },
    "suite": { "type": "string", "minLength": 1, "maxLength": 200 },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "executor_id": { "type": "string", "minLength": 1 },
    "configuration_fingerprint": { "type": "string", "minLength": 1, "maxLength": 200 },
    "attestation": { "enum": ["observed", "attested"] },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "score", "passed", "evidence_hash"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
          "role": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,62}$" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "passed": { "type": "boolean" },
          "evidence_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "raw_prompts_stored": { "const": false }
  }
}
