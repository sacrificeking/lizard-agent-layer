{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/contract-change.schema.json",
  "title": "lizard-agent-layer contract change declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "date", "summary", "changed_paths", "decision_records", "migration", "compatibility"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,80}$" },
    "date": { "type": "string", "format": "date" },
    "summary": { "type": "string", "minLength": 20 },
    "changed_paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "decision_records": { "type": "array", "items": { "type": "string", "pattern": "^docs/adr/[0-9]{4}-[a-z0-9-]+\\.md$" }, "minItems": 1, "uniqueItems": true },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "note"],
      "properties": {
        "disposition": { "enum": ["migration-required", "backward-compatible", "not-applicable"] },
        "note": { "type": "string", "minLength": 12 }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impact", "note"],
      "properties": {
        "impact": { "enum": ["none", "additive", "breaking"] },
        "note": { "type": "string", "minLength": 12 }
      }
    }
  }
}
