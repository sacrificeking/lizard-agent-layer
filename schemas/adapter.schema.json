{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/adapter.schema.json",
  "title": "lizard-agent-layer adapter manifest",
  "type": "object",
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    }
  },
  "required": ["name", "description", "instruction", "skillMirrors"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "description": { "type": "string" },
    "compatibility": {
      "type": "object",
      "required": ["instructionGroup", "precedence"],
      "properties": {
        "instructionGroup": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
        "precedence": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "instruction": {
      "type": "object",
      "required": ["src", "dst"],
      "properties": {
        "src": { "$ref": "#/$defs/safeRelativePath" },
        "dst": { "$ref": "#/$defs/safeRelativePath" },
        "sidecar": { "$ref": "#/$defs/safeRelativePath" },
        "mergePolicy": { "enum": ["skip-if-wired", "sidecar-if-exists", "overwrite"] }
      },
      "additionalProperties": false
    },
    "skillMirrors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dst"],
        "properties": {
          "dst": { "$ref": "#/$defs/safeRelativePath" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
