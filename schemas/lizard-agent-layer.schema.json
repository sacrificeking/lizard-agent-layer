{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/lizard-agent-layer.schema.json",
  "title": "lizard-agent-layer project profile",
  "type": "object",
  "required": ["profile", "riskLevel", "memoryMode", "harnesses", "skills"],
  "properties": {
    "projectName": { "type": "string" },
    "profile": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "stack": { "type": "array", "items": { "type": "string" } },
    "projectSize": { "enum": ["small", "medium", "large"] },
    "riskLevel": { "enum": ["low", "medium", "high"] },
    "memoryMode": { "enum": ["curated", "private-episodic", "off"] },
    "harnesses": { "type": "array", "items": { "type": "string" } },
    "modelProfiles": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "deprecated": true,
      "description": "Legacy compatibility only. New configurations use modelMode, modelInventory, and modelRuntime."
    },
    "modelMode": { "enum": ["inherit-current", "inventory-routing"] },
    "modelInventory": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "modelRuntime": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "routingPolicy": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "skills": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "modelMode": { "const": "inventory-routing" } }, "required": ["modelMode"] },
      "then": {
        "required": ["modelInventory", "modelRuntime"],
        "properties": {
          "modelInventory": { "type": "string" },
          "modelRuntime": { "type": "string" }
        }
      }
    }
  ]
}
