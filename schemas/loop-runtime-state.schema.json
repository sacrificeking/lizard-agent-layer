{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.dev/schemas/loop-runtime-state.schema.json",
  "title": "lizard-agent-layer loop runtime state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pattern", "readiness_level", "revision", "status", "active_run_id", "last_run_id", "updated_at", "budget_window", "items", "runs"],
  "properties": {
    "schema_version": { "const": 1 },
    "pattern": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "readiness_level": { "enum": ["L1", "L2"] },
    "revision": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["idle", "running", "paused"] },
    "active_run_id": { "type": ["string", "null"] },
    "last_run_id": { "type": ["string", "null"] },
    "updated_at": { "type": "string", "format": "date-time" },
    "budget_window": {
      "type": "object", "additionalProperties": false,
      "required": ["date", "runs_started", "tokens_used"],
      "properties": { "date": { "type": "string", "format": "date" }, "runs_started": { "type": "integer", "minimum": 0 }, "tokens_used": { "type": "integer", "minimum": 0 } }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "consecutive_attempts", "total_attempts", "failures", "status", "last_run_id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 }, "consecutive_attempts": { "type": "integer", "minimum": 0 }, "total_attempts": { "type": "integer", "minimum": 0 }, "failures": { "type": "integer", "minimum": 0 }, "status": { "enum": ["ready", "running", "completed", "blocked"] }, "last_run_id": { "type": ["string", "null"] }
        }
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["run_id", "item_id", "owner", "operation_id", "status", "started_at", "completed_at", "token_estimate", "actual_tokens", "verifier_evidence_hash"],
        "properties": {
          "run_id": { "type": "string" }, "item_id": { "type": "string" }, "owner": { "type": "string" }, "operation_id": { "type": ["string", "null"] }, "status": { "enum": ["running", "completed", "failed", "recovered"] }, "started_at": { "type": "string", "format": "date-time" }, "completed_at": { "type": ["string", "null"], "format": "date-time" }, "token_estimate": { "type": "integer", "minimum": 1 }, "actual_tokens": { "type": ["integer", "null"], "minimum": 0 }, "verifier_evidence_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
