{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/drift-baseline.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "layer_version", "artifact_count", "total_bytes", "token_estimate", "artifacts"],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "layer_version": { "type": "string" },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "token_estimate": { "type": "integer", "minimum": 0 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256", "bytes", "lines", "words", "token_estimate"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 },
          "lines": { "type": "integer", "minimum": 0 },
          "words": { "type": "integer", "minimum": 0 },
          "token_estimate": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
