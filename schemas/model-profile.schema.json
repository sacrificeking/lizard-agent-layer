{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/model-profile.schema.json",
  "title": "lizard-agent-layer model profile",
  "type": "object",
  "required": ["name", "provider", "bestFor", "limits"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "provider": { "type": "string" },
    "bestFor": { "type": "array", "items": { "type": "string" } },
    "avoidFor": { "type": "array", "items": { "type": "string" } },
    "limits": { "type": "array", "items": { "type": "string" } },
    "handoffRole": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
