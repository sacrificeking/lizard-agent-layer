{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/loop-constraints.schema.json",
  "title": "lizard-agent-layer loop constraints",
  "type": "object",
  "required": ["schema_version", "default_mode", "denylist", "human_gates", "allowlist"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "default_mode": { "enum": ["report-only", "assisted", "unattended"] },
    "denylist": { "type": "array", "items": { "type": "string" } },
    "allowlist": { "type": "array", "items": { "type": "string" } },
    "human_gates": { "type": "array", "items": { "type": "string" } },
    "max_files_changed_without_human": { "type": "integer", "minimum": 1 },
    "auto_merge": { "type": "boolean" },
    "secrets_policy": { "type": "string" }
  },
  "additionalProperties": true
}
