{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lizard-agent-layer.local/schemas/contracts.schema.json",
  "title": "lizard-agent-layer contract registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contracts"],
  "properties": {
    "schema_version": { "const": 1 },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adr", "migration_required", "paths"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
          "adr": { "type": "string", "pattern": "^docs/adr/[0-9]{4}-[a-z0-9-]+\\.md$" },
          "migration_required": { "type": "boolean" },
          "paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true }
        }
      }
    }
  }
}
