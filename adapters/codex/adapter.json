{
  "name": "codex",
  "description": "OpenAI Codex adapter using AGENTS.md plus .agents/skills mirrors.",
  "compatibility": {
    "instructionGroup": "agents-md",
    "precedence": 100
  },
  "instruction": {
    "src": "AGENTS.lizard.md",
    "dst": "AGENTS.md",
    "sidecar": "AGENTS.lizard-agent-layer.md",
    "mergePolicy": "sidecar-if-exists"
  },
  "skillMirrors": [
    { "dst": ".agents/skills", "description": "Codex repository skill discovery path." }
  ],
  "routingCapabilities": {
    "policyMode": "advisory",
    "nativeDelegation": true,
    "modelPinning": false,
    "modelDiscovery": "none",
    "modelSelection": "inherit-current",
    "actualModelReporting": false,
    "receiptCapture": false,
    "notes": "The portable default inherits the active model. Target-local configuration must prove automatic selection before inventory routing is enabled."
  }
}
